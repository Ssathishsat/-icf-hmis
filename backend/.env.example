PORT=5000
NODE_ENV=development

# ── Local MySQL ──────────────────────────────────────────────
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=icf_hmis
# DB_SSL=false

# ── Aiven Free MySQL (production) ───────────────────────────
# Get these from: aiven.io → your MySQL service → Overview tab
DB_HOST=mysql-xxxx.aivencloud.com
DB_PORT=12345
DB_USER=avnadmin
DB_PASSWORD=your_aiven_password
DB_NAME=defaultdb
DB_SSL=true

# JWT
JWT_SECRET=icf_hmis_super_secret_jwt_key_2024
JWT_EXPIRES_IN=8h

# CORS — set to your Netlify URL in production
FRONTEND_URL=https://your-app.netlify.app
